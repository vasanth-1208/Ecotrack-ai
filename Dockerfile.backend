# Stage 1: Build
FROM node:20-alpine AS builder
WORKDIR /app
COPY backend/package*.json ./
RUN npm install
COPY backend/ ./
RUN npm run build

# Stage 2: Run
FROM node:20-alpine
WORKDIR /app
COPY backend/package*.json ./
RUN npm install --omit=dev
COPY --from=builder /app/dist ./dist
# Initialize local folder for database JSON fallback
RUN mkdir -p /app/data
EXPOSE 5000
ENV NODE_ENV=production
CMD ["npm", "start"]
